export async function logoutController(
  req: Request,
  res: Response
) {

  try {

    const { refreshToken } = req.body;

    const result =
      await logoutService(
        refreshToken
      );

    return res.json(result);

  } catch (error: any) {

    return res.status(400).json({
      error: error.message,
    });

  }
}